# Copy to .env and fill in your key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Configuration tuned for Anthropic tier-1 (8K output tokens/min).
# If you have higher rate limits, you can raise MAX_CONCURRENT_REQUESTS.
MODEL=claude-sonnet-4-6
MAX_TOKENS=2000
TEMPERATURE=0.3
MAX_CONCURRENT_REQUESTS=2
LOG_LEVEL=INFO

# Paths
CSV_PATH=data/ma_transactions_500.csv
